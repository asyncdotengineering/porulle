# Copy to `.env`. Everything here has a working default — the store runs with none of it set.

# Port the REST API listens on.
PORT=4000

# Public origin of this instance (trusted for auth cookies/CSRF, media URLs).
PUBLIC_URL=http://localhost:4000

# Where the embedded PGlite database persists. Delete this folder to reset.
PGLITE_PATH=./.data/pgdata

# ── Production: swap PGlite → real Postgres (adapter-postgres) ──────────────
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# ── Real payments: `pnpm add @porulle/adapter-stripe`, then set these ──────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Transactional email: `pnpm add @porulle/adapter-resend`, then set this ─
# RESEND_API_KEY=re_...
