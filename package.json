{
  "name": "porulle-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:check-drift": "cd apps/store-example && bunx drizzle-kit check --config drizzle.config.ts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=./packages/* && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.3.5",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/adapters/*",
    "packages/deployment/*",
    "packages/plugins/*",
    "packages/import/*"
  ],
  "overrides": {
    "drizzle-orm": "^0.45.1"
  },
  "resolutions": {
    "drizzle-orm": "^0.45.1"
  }
}
