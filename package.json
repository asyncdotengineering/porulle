{
  "name": "porulle-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:check-drift": "cd apps/store-example && pnpm exec drizzle-kit check --config drizzle.config.ts",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build --filter=./packages/** && changeset publish && git push --follow-tags"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.3.5",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.7.4",
    "turbo": "^2.8.14",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0"
}
