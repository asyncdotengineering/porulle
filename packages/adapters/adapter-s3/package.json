{
  "name": "@porulle/adapter-s3",
  "version": "0.7.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 1000",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@porulle/core": "workspace:*"
  },
  "devDependencies": {
    "@porulle/eslint-config": "workspace:*",
    "@porulle/typescript-config": "workspace:*",
    "@types/node": "^24.5.2",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "description": "StorageAdapter for AWS S3 (or any S3-compatible bucket — DigitalOcean Spaces, MinIO, Backblaze B2 with the right endpoint).",
  "homepage": "https://porulle-docs.vercel.app",
  "bugs": {
    "url": "https://github.com/asyncdotengineering/porulle/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asyncdotengineering/porulle.git",
    "directory": "packages/adapters/adapter-s3"
  },
  "author": "Porulle contributors"
}
