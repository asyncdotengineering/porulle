{
  "name": "@porulle/core",
  "version": "0.10.1",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./schema": {
      "bun": "./src/kernel/database/schema.ts",
      "import": "./dist/kernel/database/schema.js",
      "require": "./dist/kernel/database/schema.js",
      "types": "./src/kernel/database/schema.ts"
    },
    "./auth-schema": {
      "bun": "./src/auth/auth-schema.ts",
      "import": "./dist/auth/auth-schema.js",
      "require": "./dist/auth/auth-schema.js",
      "types": "./src/auth/auth-schema.ts"
    },
    "./testing": {
      "bun": "./src/testing.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.js",
      "types": "./src/testing.ts"
    },
    "./drizzle": {
      "bun": "./src/drizzle.ts",
      "import": "./dist/drizzle.js",
      "require": "./dist/drizzle.js",
      "types": "./src/drizzle.ts"
    }
  },
  "scripts": {
    "generate:plugins": "node ./scripts/generate-plugin-types.mjs",
    "check:store-guard": "node ./scripts/check-store-guard.mjs",
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && npm run generate:plugins && npm run check:store-guard && tsc -p tsconfig.build.json",
    "check-types": "npm run generate:plugins && npm run check:store-guard && tsc --noEmit",
    "lint": "eslint . --max-warnings 1000",
    "test": "vitest run"
  },
  "dependencies": {
    "@better-auth/api-key": "^1.3.8",
    "@better-auth/drizzle-adapter": "^1.3.8",
    "@hono/zod-openapi": "^1.2.2",
    "@scalar/hono-api-reference": "^0.10.5",
    "better-auth": "^1.3.8",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.9.8",
    "hono-rate-limiter": "^0.5.3",
    "pino": "^10.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@porulle/eslint-config": "workspace:*",
    "@porulle/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "description": "The kernel — services, adapters, hooks, state machines, auth, runtime. Everything else in the monorepo composes on top of it.",
  "homepage": "https://porulle-docs.vercel.app",
  "bugs": {
    "url": "https://github.com/asyncdotengineering/porulle/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asyncdotengineering/porulle.git",
    "directory": "packages/core"
  },
  "author": "Porulle contributors"
}
