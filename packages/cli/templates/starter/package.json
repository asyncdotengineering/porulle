{
  "name": "my-commerce",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx tsx watch src/dev-server.ts",
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit",
    "db:push": "bunx drizzle-kit push --config drizzle.config.ts",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@porulle/adapter-local-storage": "^0.5.0",
    "@porulle/adapter-postgres": "^0.5.0",
    "@porulle/core": "^0.5.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
